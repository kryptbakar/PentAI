# PostgreSQL connection string used by lib/db and the api-server.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sentinel

# Port the api-server listens on.
PORT=8080

# Docker must be installed and running locally — the recon/scan adapters
# (nmap, subfinder, httpx, nuclei) each run in a throwaway container and pull
# their image on first use. No API keys are required for these four tools.
