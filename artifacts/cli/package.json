{
  "name": "@kryptbakar/pentai",
  "version": "0.1.0",
  "description": "Autonomous, authorization-first web pentesting from your terminal.",
  "license": "MIT",
  "author": "Muhammad Abubakar (kryptbakar)",
  "type": "module",
  "bin": {
    "pentai": "dist/pentai.mjs"
  },
  "files": ["dist", "README.md"],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "start": "node ./dist/pentai.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "node ./build.mjs"
  },
  "keywords": [
    "pentest",
    "penetration-testing",
    "security",
    "cli",
    "nuclei",
    "nmap",
    "recon",
    "vulnerability-scanner",
    "appsec",
    "infosec"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kryptbakar/PentAI.git",
    "directory": "artifacts/cli"
  },
  "homepage": "https://github.com/kryptbakar/PentAI/tree/main/artifacts/cli#readme",
  "bugs": {
    "url": "https://github.com/kryptbakar/PentAI/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@workspace/engine": "workspace:*",
    "@types/node": "catalog:",
    "esbuild": "0.27.3"
  }
}
